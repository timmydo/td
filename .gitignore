# Per-rung scratch dirs; kept on a red run for triage, removed on green.
.run-scratch/
.store-register-scratch/
.store-add-scratch/
.store-add-tree-scratch/
.store-gc-scratch/
.store-gc-sweep-scratch/
.store-verify-scratch/
.store-add-referenced-scratch/
.build-hermetic-scratch/
.build-daemon-scratch/
# cargo-test: scratch CARGO_HOME + CARGO_TARGET_DIR (clean compile each run).
.cargo-test-scratch/
# recipe-rs: scratch CARGO_HOME + CARGO_TARGET_DIR + a local `cargo build` target.
.recipe-rs-scratch/
# Engine workspace `cargo build` output — builder/recipes/engine now share ONE
# target dir at the workspace root (was recipes/target/ + builder/target/).
/target/

# check-memo verdicts (constraint 2): host-local state,
# NEVER committed — a verdict greens only the environment that recorded it.
.check-verdicts/

# td-check-repro verdicts: same host-local, never-committed
# rule — memoizes the td-builder check double-build (kept separate from
# .check-verdicts/ to avoid the per-drv verdict-filename collision).
.td-check-verdicts/

.store-backend-scratch/

# Persistent content-addressed build-recipe cache (skip-if-already-realized).
.td-build-cache

# Daily-backstop runner state (ci/daily-full-suite.sh): last all-green main commit +
# the latest machine-readable verdict. Local to the runner host, not versioned.
.td-last-green
.td-daily-verdict

# Ad-hoc captured ./check.sh run logs (e.g. a backgrounded full-loop run). Transient
# host-local output, never versioned.
.check-*.log

# Claude Code session runtime state — session-specific, never versioned.
.claude/scheduled_tasks.lock
